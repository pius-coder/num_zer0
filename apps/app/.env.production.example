# Backend URL for proxy (used by Nitro RouteRules)
AURA_BACKEND_URL=http://localhost:3001

# Frontend URL (used by Hono proxy in Option C)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=3001

# Database
DATABASE_URL=postgresql://localhost:5432/aura

# Aura
AURA_SECRET_KEY=
AURA_CONSOLE_URL=http://localhost:3001
VITE_AURA_URL=http://localhost:3001

# S3 (file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
