{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "composite": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@aura-js/core/*": ["./packages/aura/src/*"],
      "@/aura/_generated/*": ["./apps/app/src/aura/_generated/*"],
      "@/aura/*": ["./packages/aura/src/*"],
      "@/*": ["./apps/app/src/*"],
      "@aura/core": ["./packages/core/src/index.ts"],
      "@aura/core/*": ["./packages/core/src/*"],
      "@aura/server-hono": ["./packages/server-hono/src/index.ts"],
      "@aura/server-hono/*": ["./packages/server-hono/src/*"],
      "@aura/client-react": ["./packages/client-react/src/index.ts"],
      "@aura/client-react/*": ["./packages/client-react/src/*"],
      "@aura/prisma": ["./packages/prisma/src/index.ts"],
      "@aura/prisma/*": ["./packages/prisma/src/*"],
      "@aura/cli": ["./packages/cli/src/index.ts"],
      "@aura/cli/*": ["./packages/cli/src/*"],
      "@aura/auth": ["./packages/plugins/auth/src/index.ts"],
      "@aura/auth/*": ["./packages/plugins/auth/src/*"],
      "@aura/storage": ["./packages/plugins/storage/src/index.ts"],
      "@aura/storage/*": ["./packages/plugins/storage/src/*"],
      "@aura/cron": ["./packages/plugins/cron/src/index.ts"],
      "@aura/cron/*": ["./packages/plugins/cron/src/*"],
      "@aura/notifications": ["./packages/plugins/notifications/src/index.ts"],
      "@aura/notifications/*": ["./packages/plugins/notifications/src/*"],
      "@aura/observability": ["./packages/plugins/observability/src/index.ts"],
      "@aura/observability/*": ["./packages/plugins/observability/src/*"],
      "@aura/http-actions": ["./packages/plugins/http-actions/src/index.ts"],
      "@aura/http-actions/*": ["./packages/plugins/http-actions/src/*"],
      "@aura/realtime": ["./packages/plugins/realtime/src/index.ts"],
      "@aura/realtime/*": ["./packages/plugins/realtime/src/*"],
      "@aura/sms-providers": ["./packages/plugins/sms-providers/src/index.ts"],
      "@aura/sms-providers/*": ["./packages/plugins/sms-providers/src/*"],
      "@aura/dashboard": ["./packages/plugins/dashboard/src/index.ts"],
      "@aura/dashboard/*": ["./packages/plugins/dashboard/src/*"],
      "@aura/workflows": ["./packages/plugins/workflows/src/index.ts"],
      "@aura/workflows/*": ["./packages/plugins/workflows/src/*"]
    }
  }
}
