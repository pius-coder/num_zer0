{
  "name": "@aura-js/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./shared": {
      "types": "./src/shared/manifest.ts",
      "default": "./src/shared/manifest.ts"
    },
    "./core": {
      "types": "./src/core/types.ts",
      "default": "./src/core/types.ts"
    },
    "./cli/*": {
      "default": "./src/cli/*.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1046.0",
    "@hono/node-server": "^1.13.2",
    "@prisma/client": "^7",
    "hono": "^4.12.18",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "prisma": "^7"
  }
}
