{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/aura/_generated/*": ["./src/_generated/*"],
      "@/aura/*": ["./src/*"],
      "@/generated/prisma/*": ["../../apps/app/src/generated/prisma/*"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src"]
}
