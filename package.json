{
  "name": "num_zer0",
  "private": true,
  "workspaces": ["packages/*", "packages/plugins/*", "apps/*"],
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.1"
  },
  "scripts": {
    "dev": "bun run --parallel --filter @aura-js/app --filter @aura/realtime dev",
    "dev:app": "bun run --filter @aura-js/app dev",
    "dev:realtime": "bun run --filter @aura/realtime dev",
    "build": "bun run --filter @aura-js/core build && bun run --filter @aura-js/app build",
    "test": "bun run --filter @aura-js/core test && bun run --filter @aura-js/app test",
    "clean": "rm -rf packages/*/{dist,.output,node_modules} apps/*/{dist,.output,node_modules} node_modules"
  },
  "dependencies": {
    "@tanstack/react-devtools": "^0.10.5"
  }
}
