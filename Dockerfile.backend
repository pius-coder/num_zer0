FROM oven/bun:latest AS build
WORKDIR /app
COPY package.json bun.lock ./
COPY apps/app/package.json apps/app/tsconfig.json apps/app/
COPY packages/aura/package.json packages/aura/
RUN bun install --frozen-lockfile
COPY . .
RUN bun run build:backend --cwd apps/app

FROM oven/bun:latest
WORKDIR /app
COPY --from=build /app/apps/app/build/backend ./backend
COPY --from=build /app/apps/app/src/generated ./generated
ENV PORT=3001
EXPOSE 3001
CMD ["bun", "backend/server-hono.js"]
