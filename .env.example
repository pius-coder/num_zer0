# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://user:password@host:5432/numzero?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/numzero

# =============================================================================
# APP
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# =============================================================================
# AUTH
# =============================================================================

BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# GRIZZLYSMS (external SMS provider)
# =============================================================================

GRIZZLY_API_KEY=

# =============================================================================
# FAPSHI (Mobile Money payments — Cameroon)
# =============================================================================

FAPSHI_API_KEY=
FAPSHI_API_USER=
FAPSHI_ENVIRONMENT=sandbox

# =============================================================================
# SMSMAN (backup SMS provider, optional)
# =============================================================================

SMSMAN_API_KEY=
SMSMAN_BASE_URL=https://api.sms-man.com/control

# =============================================================================
# ADMIN
# =============================================================================

ADMIN_EMAILS=
INTERNAL_API_SECRET=

# =============================================================================
# EMAIL
# =============================================================================

EMAIL_PROVIDER=log

# RESEND_API_KEY=
# RESEND_DOMAIN=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
DEFAULT_FROM_EMAIL=noreply@numzero.com
DEFAULT_FROM_NAME=NumZero

# =============================================================================
# SOCIAL AUTH (optional)
# =============================================================================

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# =============================================================================
# DEV
# =============================================================================

SEED_LIMIT=200
